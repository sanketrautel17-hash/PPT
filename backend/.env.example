# ─── MongoDB ──────────────────────────────────────────────────────────────────
MONGO_DB_URL=mongodb://localhost:27017/
MONGODB_DB_NAME=ppt_generator

# ─── Groq LLM ─────────────────────────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here

# ─── Model Selection (swap without code changes) ──────────────────────────────
PLANNER_MODEL=llama-3.3-70b-versatile
GUIDANCE_MODEL=llama-3.1-8b-instant

# ─── Limits ───────────────────────────────────────────────────────────────────
MAX_TEMPLATE_SIZE_MB=50
MAX_PROMPT_CHARS=8000
MAX_RETRIES=2

# ─── App ──────────────────────────────────────────────────────────────────────
APP_ENV=dev
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
